fof('T-Weak-FreeVar',axiom,
    ! [Vx,VS,VC,Ve,VT] :
      ( ( ~ visFreeVar(Vx,Ve)
        & vtcheck(VC,Ve,VT) )
     => vtcheck(vbind(Vx,VS,VC),Ve,VT) ) ).

fof('T-subst',axiom,
    ! [VT,VC,Vx,Ve,Ve2,VT2] :
      ( ( vtcheck(VC,Ve,VT)
        & vtcheck(vbind(Vx,VT,VC),Ve2,VT2) )
     => vtcheck(VC,vsubst(Vx,Ve,Ve2),VT2) ) ).

fof('T-Weak',axiom,
    ! [Vx,VS,VC,Ve,VT] :
      ( ( vlookup(Vx,VC) = vnoType
        & vtcheck(VC,Ve,VT) )
     => vtcheck(vbind(Vx,VS,VC),Ve,VT) ) ).

fof('T-Strong',axiom,
    ! [Vx,VS,VC,Ve,VT] :
      ( ( ~ visFreeVar(Vx,Ve)
        & vtcheck(vbind(Vx,VS,VC),Ve,VT) )
     => vtcheck(VC,Ve,VT) ) ).

fof('T-Preservation-T-abs-IH',axiom,
    ! [VC,Veout,VT] :
      ( ( vreduce(ve1) = vsomeExp(Veout)
        & vtcheck(VC,ve1,VT) )
     => vtcheck(VC,Veout,VT) ) ).

fof('T-Preservation-T-abs',conjecture,
    ! [Vx,VS,VC,Veout,VT] :
      ( ( vreduce(vabs(Vx,VS,ve1)) = vsomeExp(Veout)
        & vtcheck(VC,vabs(Vx,VS,ve1),VT) )
     => vtcheck(VC,Veout,VT) ) ).

