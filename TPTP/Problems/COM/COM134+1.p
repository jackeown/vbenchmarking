fof('T-subst-app',conjecture,
    ! [VT,VC,Vx,Ve,VT2] :
      ( ( vtcheck(VC,Ve,VT)
        & vtcheck(vbind(Vx,VT,VC),vapp(ve1,ve2),VT2) )
     => vtcheck(VC,vsubst(Vx,Ve,vapp(ve1,ve2)),VT2) ) ).

