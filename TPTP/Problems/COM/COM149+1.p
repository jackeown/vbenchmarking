fof('T-Weak',axiom,
    ! [Vx,VS,VC,Ve,VT] :
      ( ( vlookup(Vx,VC) = vnoType
        & vtcheck(VC,Ve,VT) )
     => vtcheck(vbind(Vx,VS,VC),Ve,VT) ) ).

fof('T-Strong',axiom,
    ! [Vx,VS,VC,Ve,VT] :
      ( ( ~ visFreeVar(Vx,Ve)
        & vtcheck(vbind(Vx,VS,VC),Ve,VT) )
     => vtcheck(VC,Ve,VT) ) ).

fof('T-Progress-T-var',conjecture,
    ! [VT,Vx] :
      ( ( vtcheck(vempty,vvar(Vx),VT)
        & ~ visValue(vvar(Vx)) )
     => ? [Veout] : vreduce(vvar(Vx)) = vsomeExp(Veout) ) ).

