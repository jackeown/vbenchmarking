                  ( ( $lesseq(0,81)
                    & ( Cs1 = tb2t(set(int,int,t2tb(Cs),t2tb1(1),t2tb1(1))) ) )
                 => ( $lesseq(0,2)
                    & $less(2,81)
                    & ! [Cs2: map_int_int] :
                        ( ( $lesseq(0,81)
                          & ( Cs2 = tb2t(set(int,int,t2tb(Cs1),t2tb1(2),t2tb1(2))) ) )
                       => ( $lesseq(0,3)
                          & $less(3,81)
                          & ! [Cs3: map_int_int] :
                              ( ( $lesseq(0,81)
                                & ( Cs3 = tb2t(set(int,int,t2tb(Cs2),t2tb1(3),t2tb1(3))) ) )
                             => ( $lesseq(0,4)
                                & $less(4,81)
                                & ! [Cs4: map_int_int] :
                                    ( ( $lesseq(0,81)
                                      & ( Cs4 = tb2t(set(int,int,t2tb(Cs3),t2tb1(4),t2tb1(4))) ) )
                                   => ( $lesseq(0,5)
