    ! [A: $tType,B: $tType,X: A,Xs: list @ A,F2: B > A,Ys2: list @ B] :
      ( ( ( cons @ A @ X @ Xs )
        = ( map @ B @ A @ F2 @ Ys2 ) )
     => ? [Z: B,Zs2: list @ B] :
          ( ( Ys2
            = ( cons @ B @ Z @ Zs2 ) )
          & ( X
            = ( F2 @ Z ) )
          & ( Xs
            = ( map @ B @ A @ F2 @ Zs2 ) ) ) ) ).

% Cons_eq_map_D
thf(fact_248_map__eq__Cons__D,axiom,
    ! [B: $tType,A: $tType,F2: B > A,Xs: list @ B,Y: A,Ys2: list @ A] :
      ( ( ( map @ B @ A @ F2 @ Xs )
        = ( cons @ A @ Y @ Ys2 ) )
     => ? [Z: B,Zs2: list @ B] :
          ( ( Xs
            = ( cons @ B @ Z @ Zs2 ) )
          & ( ( F2 @ Z )
            = Y )
          & ( ( map @ B @ A @ F2 @ Zs2 )
            = Ys2 ) ) ) ).

