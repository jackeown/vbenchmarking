thf(conj_3,hypothesis,
    less @ b @ ( sup @ b @ c ) ).

thf(conj_4,hypothesis,
    ( ( inf @ c @ ( sup @ b @ c ) )
    = c ) ).

thf(conj_5,conjecture,
    $false ).

