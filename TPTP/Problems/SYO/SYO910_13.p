tff('$ki_world_type',type,
    '$ki_world': $tType ).

tff('$ki_local_world_decl',type,
    '$ki_local_world': '$ki_world' ).

tff('$ki_accessible_decl',type,
    '$ki_accessible': ( '$ki_world' * '$ki_world' ) > $o ).

tff(p_decl,type,
    p: '$ki_world' > $o ).

tff(q_decl,type,
    q: '$ki_world' > $o ).

tff(verify,conjecture,
    ( ( ! [W: '$ki_world'] :
          ( '$ki_accessible'('$ki_local_world',W)
         => p(W) )
      & ? [W: '$ki_world'] :
          ( '$ki_accessible'('$ki_local_world',W)
          & ! [W0: '$ki_world'] :
              ( '$ki_accessible'(W,W0)
             => ( p(W0)
               => q(W0) ) ) ) )
   => ? [W: '$ki_world'] :
        ( '$ki_accessible'('$ki_local_world',W)
        & q(W) ) ) ).

