tff(verify,conjecture,
    ( ! [W: '$ki_world'] :
        ( '$ki_accessible'('$ki_local_world',W)
       => ( p(W)
         => ~ p(W) ) )
  <=> ~ ? [W: '$ki_world'] :
          ( '$ki_accessible'('$ki_local_world',W)
          & p(W) ) ) ).

