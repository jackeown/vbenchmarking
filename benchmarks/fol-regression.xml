<!DOCTYPE benchmark PUBLIC "+//IDN sosy-lab.org//DTD BenchExec benchmark 1.18//EN" "https://www.sosy-lab.org/benchexec/benchmark-1.18.dtd">
<benchmark
    tool="vampire"
    memlimit="8 GB"
    cpuCores="1">

<option name="--input_syntax">tptp</option>
<option name="--newcnf">on</option>
<option name="-t">30s</option>
<option name="-i">20000</option>
<option name="-p">off</option>

<rundefinition name="discount">
    <option name="-sa">discount</option>
</rundefinition>

<rundefinition name="otter">
    <option name="-sa">otter</option>
</rundefinition>

<tasks>
    <includesfile>tptp_CNF.set</includesfile>
    <includesfile>tptp_FOF.set</includesfile>
    <includesfile>tptp_TF0.set</includesfile>
    <includesfile>tptp_TF1.set</includesfile>
    <includesfile>tptp_TX0.set</includesfile>
    <includesfile>tptp_TX1.set</includesfile>
</tasks>

<columns>
    <column title="szs-status">szs-status</column>
    <column title="instruction-count">instruction-count</column>
</columns>

</benchmark>
<!-- vim:fenc=utf-8 -->
